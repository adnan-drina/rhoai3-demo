# Git repository for Argo CD
GIT_REPO_URL=https://github.com/adnan-drina/rhoai3-demo.git
GIT_REPO_BRANCH=main

# Safety guard: scripts refuse live OpenShift work unless the current API server
# contains this substring. Use a unique cluster id or full API hostname.
RHOAI_EXPECTED_API_SERVER=
# RHOAI_ALLOW_UNGUARDED_CLUSTER=false
# RHOAI_OC_REQUEST_TIMEOUT=10s

# Optional project-local kubeconfig. Use an absolute path so scripts and hooks
# resolve it consistently from any working directory. Never commit kubeconfigs;
# /tmp/ and *.kubeconfig are ignored.
# KUBECONFIG=/absolute/path/to/rhoai3-demo/tmp/current-cluster.kubeconfig

# Stage 110 demo user passwords (setup-access.sh). If unset, random passwords are
# generated and appended here. Set them to use fixed demo credentials instead.
# AI_ADMIN_PASSWORD=
# AI_DEVELOPER_PASSWORD=

# HuggingFace token (for step-03)
# HF_TOKEN=

# OpenAI provider key for Stage 230 external MaaS models.
# Keep provider credentials local to this project by default. Set
# RHOAI_OPENAI_ENV_FILE explicitly only when cross-project credential reuse is
# intentional and approved.
# OPENAI_API_KEY=
# RHOAI_OPENAI_ENV_FILE=

# Git repository for Argo CD
GIT_REPO_URL=https://github.com/adnan-drina/rhoai3-demo.git
GIT_REPO_BRANCH=main

# Safety guard: scripts refuse live OpenShift work unless the current API server
# contains this substring. Use a unique cluster id or full API hostname.
RHOAI_EXPECTED_API_SERVER=
# RHOAI_ALLOW_UNGUARDED_CLUSTER=false
# RHOAI_OC_REQUEST_TIMEOUT=10s

# Optional project-local kubeconfig. Use an absolute path so scripts and hooks
# resolve it consistently from any working directory. Never commit kubeconfigs;
# /tmp/ and *.kubeconfig are ignored.
# KUBECONFIG=/absolute/path/to/rhoai3-demo/tmp/current-cluster.kubeconfig

# Stage 110 demo user passwords (setup-access.sh). If unset, random passwords are
# generated and appended here. Set them to use fixed demo credentials instead.
# AI_ADMIN_PASSWORD=
# AI_DEVELOPER_PASSWORD=

# Stage 210 model-serving defaults. Override only when the demo model, registry,
# namespace, queue, or hardware profile changes.
# MODEL_REGISTRY_NAMESPACE=rhoai-model-registries
# MODEL_REGISTRY_NAME=demo-registry
# RHOAI_MODEL_NAMESPACE=demo-sandbox
# RHOAI_NEMOTRON_DEPLOYMENT_NAME=nvidia-nemotron-3-nano-30b-a3b
# RHOAI_NEMOTRON_DISPLAY_NAME=NVIDIA-Nemotron-3-Nano-30B-A3B-FP8
# RHOAI_NEMOTRON_VERSION_NAME=Version 1
# RHOAI_NEMOTRON_MODEL_URI=oci://registry.redhat.io/rhai/modelcar-nvidia-nemotron-3-nano-30b-a3b-fp8:3.0
# RHOAI_NEMOTRON_SOURCE_NAME=RedHatAI/NVIDIA-Nemotron-3-Nano-30B-A3B-FP8
# RHOAI_NEMOTRON_PULL_SECRET=nemotron-3-nano-30b
# RHOAI_NEMOTRON_RUNTIME_NAME=vllm-cuda-runtime
# RHOAI_NEMOTRON_QUEUE_NAME=lq-gpu-reserved-demo
# RHOAI_NEMOTRON_HARDWARE_PROFILE=gpu-reserved-demo

# Stage 210 GuideLLM benchmark defaults. The default profile follows the
# llm-d showroom Module 2 pattern: /data/prompts.csv from the benchmark-data
# PVC, concurrent rates 32 and 64, and 30 seconds per rate. Override these for
# quick smoke tests.
# RHOAI_GUIDELLM_IMAGE=ghcr.io/vllm-project/guidellm:v0.5.0
# RHOAI_GUIDELLM_DATA_PVC=benchmark-data
# RHOAI_GUIDELLM_DATA=/data/prompts.csv
# RHOAI_GUIDELLM_RATE_TYPE=concurrent
# RHOAI_GUIDELLM_RATE=32,64
# RHOAI_GUIDELLM_MAX_SECONDS=30
# RHOAI_GUIDELLM_OUTPUTS=benchmark-results.json,benchmark-results.csv
# RHOAI_GUIDELLM_TARGET_SUFFIX=/v1

# Stage 220 MaaS defaults. Provider keys and database passwords stay local and
# are converted into OpenShift Secrets by stage-220-models-as-a-service/deploy.sh.
# RHOAI_MAAS_NAMESPACE=models-as-a-service
# RHOAI_MAAS_POSTGRES_SECRET=maas-postgres-credentials
# RHOAI_MAAS_POSTGRES_USER=maas
# RHOAI_MAAS_POSTGRES_DATABASE=maas
# RHOAI_MAAS_DB_CONFIG_SECRET=maas-db-config
# RHOAI_OPENAI_MODEL_ID=gpt-4o-mini
# RHOAI_OPENAI_PROVIDER_SECRET=openai-provider-api-key

# HuggingFace token (reserved for future model/data workflows)
# HF_TOKEN=

# OpenAI provider key for Stage 220 external MaaS models.
# Keep provider credentials local to this project by default. Set
# RHOAI_OPENAI_ENV_FILE explicitly only when cross-project credential reuse is
# intentional and approved.
# OPENAI_API_KEY=
# RHOAI_OPENAI_API_KEY=
# RHOAI_OPENAI_ENV_FILE=

# Stage 230 private RAG defaults. Secrets are generated or copied by
# stage-230-private-data-rag/deploy.sh and must not be committed.
# RHOAI_STAGE230_NAMESPACE=enterprise-rag
# RHOAI_STAGE230_POSTGRES_SECRET=private-rag-postgres-credentials
# RHOAI_STAGE230_POSTGRES_USER=rag
# RHOAI_STAGE230_POSTGRES_DATABASE=llamastack
# RHOAI_STAGE230_MILVUS_SECRET=private-rag-milvus-secret
# RHOAI_STAGE230_LLAMA_STACK_SECRET=private-rag-llama-stack-secret
# RHOAI_STAGE230_MAAS_SUBSCRIPTION=rhoai-developers-gpt-4o-mini
# RHOAI_STAGE230_MAAS_API_KEY=
# RHOAI_STAGE230_INFERENCE_MODEL=nemotron-3-nano-30b-a3b
# RHOAI_STAGE230_VLLM_MAX_TOKENS=1024
